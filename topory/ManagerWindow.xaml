<Window x:Class="topory.ManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:topory"
        xmlns:services="clr-namespace:topory.Services"
        mc:Ignorable="d"
        Title="{Binding [ManagerTitle], Source={x:Static services:Localization.Instance}}"
        Width="560" Height="460"
        WindowStyle="None"
        ResizeMode="NoResize"
        AllowsTransparency="True"
        Background="Transparent"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI">

    <Window.Resources>
        <!-- Small borderless "close" button shown in the custom title bar. -->
        <Style x:Key="CloseButtonStyle" TargetType="Button">
            <Setter Property="Width" Value="24" />
            <Setter Property="Height" Value="24" />
            <Setter Property="Foreground" Value="{DynamicResource TextMuted}" />
            <Setter Property="Background" Value="Transparent" />
            <Setter Property="BorderThickness" Value="0" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Margin" Value="6,0,0,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="5" Background="{TemplateBinding Background}">
                            <TextBlock Text="✕" HorizontalAlignment="Center" VerticalAlignment="Center"
                                       Foreground="{TemplateBinding Foreground}"
                                       FontSize="{TemplateBinding FontSize}" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SurfaceHover}" />
                                <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="CmdButton" TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
            <Setter Property="Background" Value="{DynamicResource Surface}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Margin" Value="3,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="6" Background="{TemplateBinding Background}" Padding="12,6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SurfaceHover}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource CmdButton}">
            <Setter Property="Background" Value="{DynamicResource Accent}" />
            <Setter Property="Foreground" Value="White" />
        </Style>
    </Window.Resources>

    <!-- Outer margin leaves room for the drop shadow; the card is the Border. -->
    <Border Margin="12" CornerRadius="12"
            Background="{DynamicResource PanelBg}"
            BorderBrush="{DynamicResource Divider}" BorderThickness="1">
        <Border.Effect>
            <DropShadowEffect Color="#000000" Opacity="0.22" BlurRadius="20" ShadowDepth="0" />
        </Border.Effect>

        <DockPanel>

            <!-- Toolbar doubles as the custom title bar: brand + name, action
                 buttons, and a close button. The whole bar is draggable. -->
            <Border DockPanel.Dock="Top" Background="{DynamicResource ToolbarBg}"
                    CornerRadius="12,12,0,0" Padding="14,12"
                    MouseLeftButtonDown="OnHeaderDrag">
                <DockPanel>
                    <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                        <Border Width="16" Height="16" CornerRadius="4" Background="{DynamicResource Accent}" />
                        <TextBlock Text="topory" Margin="9,0,0,0" FontWeight="SemiBold" FontSize="15"
                                   Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center" />
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Style="{StaticResource PrimaryButton}" Click="OnPin"
                                Content="{Binding [TrayPin], Source={x:Static services:Localization.Instance}}" />
                        <Button Style="{StaticResource CmdButton}" Click="OnUnpinAll"
                                Content="{Binding [UnpinAll], Source={x:Static services:Localization.Instance}}" />
                        <Button Style="{StaticResource CloseButtonStyle}" Click="OnCloseClick" />
                    </StackPanel>
                </DockPanel>
            </Border>

            <!-- Hint. -->
            <Border DockPanel.Dock="Bottom" Background="{DynamicResource ToolbarBg}"
                    CornerRadius="0,0,12,12" Padding="14,8">
                <TextBlock Text="{Binding [Hint], Source={x:Static services:Localization.Instance}}"
                           FontSize="12" Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap" />
            </Border>

            <!-- List of pinned windows. -->
            <Grid Background="{DynamicResource PanelBg}">
                <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="10">
                    <ItemsControl x:Name="PinnedList">
                        <ItemsControl.ItemTemplate>
                            <DataTemplate>
                                <Border CornerRadius="8" Background="{DynamicResource Surface}" Margin="0,0,0,8" Padding="12,8">
                                    <DockPanel>
                                        <Button DockPanel.Dock="Right" Style="{StaticResource CmdButton}"
                                                Click="OnUnpin"
                                                Content="{Binding [Unpin], Source={x:Static services:Localization.Instance}}" />
                                        <TextBlock Text="{Binding Title}" VerticalAlignment="Center"
                                                   TextTrimming="CharacterEllipsis"
                                                   Foreground="{DynamicResource TextPrimary}" FontSize="13" />
                                    </DockPanel>
                                </Border>
                            </DataTemplate>
                        </ItemsControl.ItemTemplate>
                    </ItemsControl>
                </ScrollViewer>

                <TextBlock x:Name="EmptyState"
                           Text="{Binding [Empty], Source={x:Static services:Localization.Instance}}"
                           HorizontalAlignment="Center" VerticalAlignment="Center"
                           TextAlignment="Center" TextWrapping="Wrap" MaxWidth="360"
                           FontSize="13" Foreground="{DynamicResource TextMuted}" IsHitTestVisible="False" />
            </Grid>
        </DockPanel>
    </Border>
</Window>
