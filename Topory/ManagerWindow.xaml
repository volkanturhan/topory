<Window x:Class="Topory.ManagerWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:Topory"
        xmlns:services="clr-namespace:Topory.Services"
        mc:Ignorable="d"
        Title="{Binding [ManagerTitle], Source={x:Static services:Localization.Instance}}"
        Width="560" Height="460"
        MinWidth="420" MinHeight="300"
        WindowStartupLocation="CenterScreen"
        FontFamily="Segoe UI"
        Background="{DynamicResource WindowBg}">

    <Window.Resources>
        <Style x:Key="CmdButton" TargetType="Button">
            <Setter Property="Foreground" Value="{DynamicResource TextPrimary}" />
            <Setter Property="Background" Value="{DynamicResource Surface}" />
            <Setter Property="FontSize" Value="13" />
            <Setter Property="Cursor" Value="Hand" />
            <Setter Property="Margin" Value="3,0" />
            <Setter Property="Template">
                <Setter.Value>
                    <ControlTemplate TargetType="Button">
                        <Border x:Name="Bd" CornerRadius="6" Background="{TemplateBinding Background}" Padding="12,6">
                            <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                        </Border>
                        <ControlTemplate.Triggers>
                            <Trigger Property="IsMouseOver" Value="True">
                                <Setter TargetName="Bd" Property="Background" Value="{DynamicResource SurfaceHover}" />
                            </Trigger>
                        </ControlTemplate.Triggers>
                    </ControlTemplate>
                </Setter.Value>
            </Setter>
        </Style>

        <Style x:Key="PrimaryButton" TargetType="Button" BasedOn="{StaticResource CmdButton}">
            <Setter Property="Background" Value="{DynamicResource Accent}" />
            <Setter Property="Foreground" Value="White" />
        </Style>
    </Window.Resources>

    <DockPanel>

        <!-- Menu bar (kept light in both themes so its text stays readable). -->
        <Menu DockPanel.Dock="Top" Background="#F9FAFB">
            <MenuItem Header="{Binding [TrayLanguage], Source={x:Static services:Localization.Instance}}">
                <MenuItem x:Name="EnglishMenuItem" Header="English" IsCheckable="True" Click="OnEnglish" />
                <MenuItem x:Name="TurkishMenuItem" Header="Türkçe" IsCheckable="True" Click="OnTurkish" />
            </MenuItem>
            <MenuItem Header="{Binding [TrayTheme], Source={x:Static services:Localization.Instance}}">
                <MenuItem x:Name="ThemeSystemItem" IsCheckable="True" Click="OnThemeSystem"
                          Header="{Binding [ThemeSystem], Source={x:Static services:Localization.Instance}}" />
                <MenuItem x:Name="ThemeDarkItem" IsCheckable="True" Click="OnThemeDark"
                          Header="{Binding [ThemeDark], Source={x:Static services:Localization.Instance}}" />
                <MenuItem x:Name="ThemeLightItem" IsCheckable="True" Click="OnThemeLight"
                          Header="{Binding [ThemeLight], Source={x:Static services:Localization.Instance}}" />
            </MenuItem>
            <MenuItem x:Name="AutoStartMenuItem" IsCheckable="True" Click="OnToggleAutoStart"
                      Header="{Binding [TrayAutostart], Source={x:Static services:Localization.Instance}}" />
            <MenuItem Click="OnAbout"
                      Header="{Binding [TrayAbout], Source={x:Static services:Localization.Instance}}" />
        </Menu>

        <!-- Toolbar. -->
        <Border DockPanel.Dock="Top" Background="{DynamicResource ToolbarBg}" Padding="14,12">
            <DockPanel>
                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                    <Border Width="16" Height="16" CornerRadius="4" Background="{DynamicResource Accent}" />
                    <TextBlock Text="Topory" Margin="9,0,0,0" FontWeight="SemiBold" FontSize="15"
                               Foreground="{DynamicResource TextPrimary}" VerticalAlignment="Center" />
                </StackPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                    <Button Style="{StaticResource PrimaryButton}" Click="OnPin"
                            Content="{Binding [TrayPin], Source={x:Static services:Localization.Instance}}" />
                    <Button Style="{StaticResource CmdButton}" Click="OnUnpinAll"
                            Content="{Binding [UnpinAll], Source={x:Static services:Localization.Instance}}" />
                </StackPanel>
            </DockPanel>
        </Border>

        <!-- Hint. -->
        <Border DockPanel.Dock="Bottom" Background="{DynamicResource ToolbarBg}" Padding="14,8">
            <TextBlock Text="{Binding [Hint], Source={x:Static services:Localization.Instance}}"
                       FontSize="12" Foreground="{DynamicResource TextMuted}" TextWrapping="Wrap" />
        </Border>

        <!-- List of pinned windows. -->
        <Grid Background="{DynamicResource PanelBg}">
            <ScrollViewer VerticalScrollBarVisibility="Auto" Padding="10">
                <ItemsControl x:Name="PinnedList">
                    <ItemsControl.ItemTemplate>
                        <DataTemplate>
                            <Border CornerRadius="8" Background="{DynamicResource Surface}" Margin="0,0,0,8" Padding="12,8">
                                <DockPanel>
                                    <Button DockPanel.Dock="Right" Style="{StaticResource CmdButton}"
                                            Click="OnUnpin"
                                            Content="{Binding [Unpin], Source={x:Static services:Localization.Instance}}" />
                                    <TextBlock Text="{Binding Title}" VerticalAlignment="Center"
                                               TextTrimming="CharacterEllipsis"
                                               Foreground="{DynamicResource TextPrimary}" FontSize="13" />
                                </DockPanel>
                            </Border>
                        </DataTemplate>
                    </ItemsControl.ItemTemplate>
                </ItemsControl>
            </ScrollViewer>

            <TextBlock x:Name="EmptyState"
                       Text="{Binding [Empty], Source={x:Static services:Localization.Instance}}"
                       HorizontalAlignment="Center" VerticalAlignment="Center"
                       TextAlignment="Center" TextWrapping="Wrap" MaxWidth="360"
                       FontSize="13" Foreground="{DynamicResource TextMuted}" IsHitTestVisible="False" />
        </Grid>
    </DockPanel>
</Window>
