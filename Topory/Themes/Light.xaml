<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Brand accent (theme-independent). -->
    <SolidColorBrush x:Key="Accent" Color="#F97316" />
    <SolidColorBrush x:Key="AccentDark" Color="#EA580C" />

    <!-- Light surfaces and text. -->
    <SolidColorBrush x:Key="WindowBg" Color="#F3F4F6" />
    <SolidColorBrush x:Key="ToolbarBg" Color="#FFFFFF" />
    <SolidColorBrush x:Key="PanelBg" Color="#F9FAFB" />
    <SolidColorBrush x:Key="Surface" Color="#E5E7EB" />
    <SolidColorBrush x:Key="SurfaceHover" Color="#D1D5DB" />
    <SolidColorBrush x:Key="SurfaceDisabled" Color="#EEF0F2" />
    <SolidColorBrush x:Key="ThumbBg" Color="#E5E7EB" />
    <SolidColorBrush x:Key="TextPrimary" Color="#111827" />
    <SolidColorBrush x:Key="TextMuted" Color="#6B7280" />
    <SolidColorBrush x:Key="DisabledText" Color="#9CA3AF" />
    <SolidColorBrush x:Key="Divider" Color="#E5E7EB" />
    <SolidColorBrush x:Key="ToolText" Color="#374151" />

</ResourceDictionary>
